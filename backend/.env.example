# Base de datos PostgreSQL (Azure o cualquier proveedor)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# JWT para autenticación
JWT_SECRET="cambia_esto_por_una_clave_secreta_muy_larga"

# Azure OpenAI 
AZURE_OPENAI_ENDPOINT="https://tu-recurso.openai.azure.com/"
AZURE_OPENAI_API_KEY="tu_api_key_aqui"
AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# Puerto (Railway lo asigna automáticamente)
PORT=3001

# Puppeteer — apunta al Chromium instalado por nixpacks en Railway
PUPPETEER_EXECUTABLE_PATH=/nix/store/chromium
