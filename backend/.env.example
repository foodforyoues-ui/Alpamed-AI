# Server
PORT=3001
NODE_ENV=development

# Database
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="your-database-url-here"

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Azure OpenAI
AZURE_OPENAI_ENDPOINT="your-endpoint-here"
AZURE_OPENAI_API_KEY="your-api-key-here"
AZURE_OPENAI_DEPLOYMENT="nutrition-gpt"

# Azure Blob Storage (Optional, if using Blob to store WhatsApp session)
AZURE_BLOB_CONNECTION_STRING="your-connection-string"
AZURE_BLOB_CONTAINER="baileys-credentials"
