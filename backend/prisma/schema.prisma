generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String?
  email     String    @unique
  password  String
  role      String    @default("user") // "admin" o "user"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profiles  Profile[] // Relación 1 a N: Un nutricionista tiene múltiples pacientes
}

model Profile {
  id                      Int                @id @default(autoincrement())
  patientName             String
  phone                   String             @unique
  realAge                 Int?
  
  // Relación con el nutricionista (Opcional temporalmente para no romper datos existentes)
  userId                  Int?
  user                    User?              @relation(fields: [userId], references: [id])

  // Hábitos (editables)
  doesExercise            Boolean            @default(false)
  exerciseType            String?
  sleepHours              Float?
  dailySteps              Int?

  // Blueprint para la IA (editables)
  generalRecommendation   String?
  specificRecommendations String[]

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  active                  Boolean            @default(true)

  snapshots               ProfileSnapshot[]
  messages                MessageLog[]
  appointments            Appointment[]
}

// Cada "Registrar Seguimiento" crea un nuevo registro aquí
model ProfileSnapshot {
  id                   Int      @id @default(autoincrement())
  profileId            Int
  profile              Profile  @relation(fields: [profileId], references: [id])

  // Mediciones de esta consulta
  weight               Float?
  bmi                  Float?
  bodyFatPercentage    Float?
  muscleMassPercentage Float?
  metabolicAge         Int?
  lostWeight           Float?

  // Peso de referencia inicial si es la primera medición
  isInitialRecord      Boolean  @default(false)

  notes                String?
  recordedAt           DateTime @default(now())
}

model MessageLog {
  id          Int      @id @default(autoincrement())
  profileId   Int
  profile     Profile  @relation(fields: [profileId], references: [id])
  content     String
  status      String   @default("generated")
  sentAt      DateTime @default(now())
}

model Appointment {
  id          Int      @id @default(autoincrement())
  profileId   Int
  profile     Profile  @relation(fields: [profileId], references: [id])
  date        DateTime
  reason      String
  status      String   @default("pendiente") // pendiente, completada, cancelada
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
